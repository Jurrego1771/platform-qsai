# === Mediastream Platform SM2 ===
# URL base de la plataforma (dev/staging/prod)
BASE_URL=https://dev.platform.mediastre.am

# Credenciales del usuario QA (sesión browser para Playwright)
CMS_USER=qa@mediastre.am
CMS_PASSWORD=

# Token de API (X-API-Token header para llamadas API en tests)
SM2_API_TOKEN=

# Account ID (necesario para algunos endpoints de SM2)
ACCOUNT_ID=

# === Configuración de entorno ===
MS_ENV=dev

# === Visual regression threshold ===
# Porcentaje de pixels diferentes que activa la alarma (0.01 = 1%)
VISUAL_DIFF_THRESHOLD=0.01

# === CI/CD ===
# Slack webhook para notificaciones de CI
SLACK_WEBHOOK_URL=

# === Allure reporting ===
ALLURE_RESULTS_DIR=allure-results
